# App base path (leave empty for local root "/")
NEXT_PUBLIC_BASE_PATH=

# Clerk (required for merchant sign-in/dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Database URL
# - For `pnpm run local`, this is auto-provided by the script.
# - Set this when running the app directly (without local-dev script).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/socialshop

# Optional app port when running web directly
PORT=23910
